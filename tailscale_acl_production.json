{
  "tagOwners": {
    "tag:server": ["bharatpurbazar@gmail.com"],
    "tag:admin":  ["bharatpurbazar@gmail.com"]
  },

  "acls": [
    // 1. Give Admin-tagged devices full access
    {
      "action": "accept",
      "src":    ["tag:admin"],
      "dst":    ["*:*"]
    },

    // 2. Allow Servers to talk to each other (Required for MultiPaper Sync)
    {
      "action": "accept",
      "src":    ["tag:server"],
      "dst":    ["tag:server:*"]
    },

    // 3. RESTRICT UNTAGGED PLAYER DEVICES (bharatpurbazar@gmail.com)
    // Players will connect untagged, inheriting your email but are restricted here
    {
      "action": "accept",
      "src":    ["bharatpurbazar@gmail.com"],
      "dst": [
        "tag:server:25565",
        "tag:server:25566",
        "tag:server:35353",
        "tag:server:24454"
      ]
    },

    // 4. MCR Matchmaking: Allow players to query ONLY the matchmaking server on port 8000
    {
      "action": "accept",
      "src":    ["bharatpurbazar@gmail.com"],
      "dst":    ["100.120.244.95:8000"]
    },

    // 5. MCR Gameplay: Allow direct peer-to-peer connection and state streaming between players
    {
      "action": "accept",
      "src":    ["bharatpurbazar@gmail.com"],
      "dst":    ["bharatpurbazar@gmail.com:25565", "bharatpurbazar@gmail.com:24454"]
    }
  ],

  "ssh": [
    {
      "action": "accept",
      "src":    ["tag:admin", "tag:server"],
      "dst":    ["tag:server"],
      "users":  ["root", "bb", "bigfish", "autogroup:nonroot"]
    }
  ]
}